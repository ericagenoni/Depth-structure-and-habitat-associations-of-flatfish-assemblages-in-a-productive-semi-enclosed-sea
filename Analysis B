## =========================================================
## 22. Procrustes and PROTEST between fish and benthos ordinations
## =========================================================

# ---------------------------------------------------------
# 22A. Build a benthos ordination on the same common hauls
# ---------------------------------------------------------
# The comparison is performed on matched sampling units only.
bray_benthos_common <- vegdist(comm_benthos_common, method = "bray")

pcoa_benthos_common <- cmdscale(bray_benthos_common, eig = TRUE, k = 2)

benthos_scores_common <- as.data.frame(pcoa_benthos_common$points[, 1:2])
colnames(benthos_scores_common) <- c("PCoA1", "PCoA2")

# Optional eigenvalue diagnostics for the benthos ordination
eig_benthos <- pcoa_benthos_common$eig
min(eig_benthos)
sum(eig_benthos < 0)
sum(eig_benthos[eig_benthos > 0]) / sum(abs(eig_benthos))

# ---------------------------------------------------------
# 22B. Procrustes analysis
# ---------------------------------------------------------
# Procrustes rotates, scales, and translates one ordination
# to best match the other, then measures residual mismatch.
proc <- procrustes(
  X = pcoa_scores_common,
  Y = benthos_scores_common,
  symmetric = TRUE
)

proc

# Procrustes residuals by haul
proc_residuals <- data.frame(
  YEAR = meta_common$YEAR,
  Strato = meta_common$Strato,
  HAUL_NUMBER = meta_common$HAUL_NUMBER,
  key = meta_common$key,
  residual = residuals(proc)
)

proc_residuals

write.csv(
  proc_residuals,
  file.path(out_dir, "FrameworkB_procrustes_residuals_by_haul.csv"),
  row.names = FALSE
)

# Base Procrustes plot
plot(proc)

# ---------------------------------------------------------
# 22C. PROTEST (permutation test for Procrustes association)
# ---------------------------------------------------------
# This tests whether the concordance between the two ordinations
# is stronger than expected by chance.
proc_test <- protest(
  X = pcoa_scores_common,
  Y = benthos_scores_common,
  permutations = 9999
)

proc_test

# Optional export of the key Procrustes statistics
proc_summary <- data.frame(
  procrustes_ss = proc$ss,
  protest_t0    = unname(proc_test$t0),
  protest_p     = unname(proc_test$signif)
)

proc_summary

write.csv(
  proc_summary,
  file.path(out_dir, "FrameworkB_procrustes_protest_summary.csv"),
  row.names = FALSE
)


